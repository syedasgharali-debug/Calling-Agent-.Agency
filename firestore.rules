rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'syedasgharkazmii@gmail.com' ||
        request.auth.token.email == 'syedasghakazmii@gmail.com' ||
        request.auth.token.email == 'essadhiif@gmail.com'
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['customer', 'admin'];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidCallLog(data) {
      return data.keys().hasAll(['userId', 'caller', 'agent', 'duration', 'cost', 'sentiment', 'timestamp', 'outcome']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.caller is string && data.caller.size() <= 64 &&
             data.agent is string && data.agent.size() <= 128 &&
             data.duration is string && data.duration.size() <= 32 &&
             data.cost is number &&
             data.sentiment in ['Positive', 'Neutral', 'Negative'] &&
             data.outcome is string && data.outcome.size() <= 256;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || userId.startsWith('fallback_');
      allow list: if isAdmin();
      allow create: if (isOwner(userId) || isAdmin() || userId.startsWith('fallback_')) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin() || (userId.startsWith('fallback_') && request.resource.data.password == resource.data.password)) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.email == resource.data.email; // Email is immutable
      allow delete: if isAdmin();
    }

    // Calls collection
    match /calls/{callId} {
      allow get: if (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin())) || resource.data.userId.startsWith('fallback_');
      allow list: if (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin())) || resource.data.userId.startsWith('fallback_');
      allow create: if (isSignedIn() && 
                    isValidId(callId) && 
                    isValidCallLog(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid) || (request.resource.data.userId.startsWith('fallback_') && isValidCallLog(request.resource.data));
      allow update, delete: if isAdmin();
    }
  }
}
